generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  organizer
  user
}

enum RegistrationStatus {
  pending
  confirmed
  canceled
  overbooked // pagou mas o estoque esgotou no momento da confirmação — aguarda reembolso manual
}

enum PaymentStatus {
  pending
  paid
  failed
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            Role             @default(user)
  createdAt       DateTime         @default(now())
  events          Event[]
  registrations   Registration[]
  volunteerEvents EventVolunteer[]
}

model Event {
  id              String               @id @default(uuid())
  title           String
  description     String?
  location        String?
  date            DateTime
  endDate         DateTime?
  bannerUrl       String?
  slug            String?              @unique
  category        String?
  maxParticipants Int?
  organizerPhone  String?
  isPublished     Boolean              @default(false)
  about           String?
  formFields      String?
  createdBy       String
  createdAt       DateTime             @default(now())
  user            User                 @relation(fields: [createdBy], references: [id])
  tickets         Ticket[]
  registrations   Registration[]
  paymentMethods  EventPaymentMethod[]
  volunteers      EventVolunteer[]
}

model EventVolunteer {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model EventPaymentMethod {
  id           String    @id @default(uuid())
  eventId      String
  type         String
  value        Decimal   @default(0)
  installments Int       @default(1)
  description  String?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  event        Event     @relation(fields: [eventId], references: [id])
}

model Ticket {
  id            String         @id @default(uuid())
  eventId       String
  name          String
  price         Decimal        @default(0)
  quantity      Int
  sold          Int            @default(0)
  createdAt     DateTime       @default(now())
  event         Event          @relation(fields: [eventId], references: [id])
  registrations Registration[]
}

model Registration {
  id          String             @id @default(uuid())
  userId      String
  eventId     String
  ticketId    String?
  status      RegistrationStatus @default(pending)
  cpf         String?
  phone       String?
  birthDate   DateTime?
  extraFields String?
  code        String?            @unique
  checkedIn               Boolean            @default(false)
  checkedInAt             DateTime?
  checkedInBy             String?
  confirmationEmailSentAt DateTime?
  createdAt               DateTime           @default(now())
  user        User               @relation(fields: [userId], references: [id])
  event       Event              @relation(fields: [eventId], references: [id])
  ticket      Ticket?            @relation(fields: [ticketId], references: [id])
  payment     Payment?
  checkinLogs CheckinLog[]
}

model CheckinLog {
  id             String       @id @default(uuid())
  registrationId String
  eventId        String
  action         String // 'check_in' | 'undo'
  performedBy    String
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id])
}

model Payment {
  id                String        @id @default(uuid())
  registrationId    String        @unique
  amount            Decimal
  status            PaymentStatus @default(pending)
  provider          String        @default("mock")
  providerPaymentId String?
  qrCodeBase64      String?
  qrCodeCopiaECola  String?
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  registration      Registration  @relation(fields: [registrationId], references: [id])
}
